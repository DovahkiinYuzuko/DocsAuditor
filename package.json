{
  "name": "docs-auditor",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "YuzukoUnderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DovahkiinYuzuko/DocsAuditor.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docs-auditor-sidebar",
          "title": "Docs Auditor",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "docs-auditor-sidebar": [
        {
          "type": "webview",
          "id": "docs-auditor-settings",
          "name": "Docs Auditor Settings"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "%config.title%",
      "properties": {
        "docsAuditor.autoInjection": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoInjection.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  }
}
